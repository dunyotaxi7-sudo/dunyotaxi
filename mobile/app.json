{
  "expo": {
    "name": "Dunyo Taxi",
    "slug": "dunyotaxi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "dunyotaxi",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Dunyo Taxi yaqin atrofdagi haydovchilarni topish va sayohatni kuzatish uchun joylashuvingizdan foydalanadi.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Haydovchi onlayn bo'lganda, ilova fonda ishlaganda ham joylashuv uzatiladi.",
        "UIBackgroundModes": [
          "location"
        ]
      },
      "bundleIdentifier": "uz.dunyotaxi.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "uz.dunyotaxi.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Dunyo Taxi yaqin atrofdagi haydovchilarni topish uchun joylashuvingizdan foydalanadi.",
          "locationAlwaysAndWhenInUsePermission": "Haydovchi onlayn bo'lganda, ilova fonda ishlaganda ham joylashuv uzatiladi.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#2563eb"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Dunyo Taxi hujjat rasmlarini yuklash uchun galereyaga kirishni so'raydi.",
          "cameraPermission": "Dunyo Taxi hujjatlarni rasmga olish uchun kameraga kirishni so'raydi."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}