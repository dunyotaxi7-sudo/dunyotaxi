# Backend base URL. Use your machine's LAN IP for real devices,
# or 10.0.2.2 (Android emulator) / 127.0.0.1 (iOS simulator).
EXPO_PUBLIC_API_URL=http://192.168.0.166:8001

# Google Maps API key from Google Cloud Console (enable "Maps SDK for Android").
# Leave blank to fall back to a map placeholder on Android (no crash).
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional Google Maps "Map ID" (cloud styling). Not consumed by
# react-native-maps 1.27; kept for future use.
EXPO_PUBLIC_GOOGLE_MAPS_MAP_ID=

# Language for geocoding/search results (address text). "uz" = O'zbekcha, "ru" = Русский.
# Requires the "Geocoding API" enabled on the key; falls back to the phone locale otherwise.
EXPO_PUBLIC_MAPS_LANGUAGE=uz
