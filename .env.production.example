# Production config — copy to .env.production on the server and fill in.
# NEVER commit the filled-in file (.gitignore already excludes .env.*).

# ── Domain (used by nginx + certbot) ─────────────────
DOMAIN=api.yourdomain.uz
[email protected]

# ── Database (compose creates it from these) ─────────
POSTGRES_DB=buxoro_taxi
POSTGRES_USER=buxoro
# Generate: openssl rand -base64 32
POSTGRES_PASSWORD=

# DATABASE_URL / REDIS_URL are set by docker-compose to point at the
# `db` and `redis` services — don't set them here.

# ── Environment ──────────────────────────────────────
ENVIRONMENT=production
DEBUG=false

# ── JWT — MUST change ────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=
# 30 days is far too long for production; 60 min + refresh token is sane.
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=129600

# ── CORS — lock to the admin panel origin ────────────
# e.g. https://admin.yourdomain.uz  (never "*" in production)
CORS_ORIGINS=https://admin.yourdomain.uz

# ── OTP ──────────────────────────────────────────────
OTP_TTL_SECONDS=120
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=5
# Must stay false in production (only honoured for SMS_PROVIDER=mock anyway).
OTP_DEBUG_RETURN=false
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_PER_PHONE_HOUR=5
OTP_MAX_PER_PHONE_DAY=10
OTP_MAX_PER_IP_HOUR=20

# ── SMS (Eskiz.uz) ───────────────────────────────────
SMS_PROVIDER=eskiz
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_FROM=4546
# Must EXACTLY match a template approved in your Eskiz account.
OTP_MESSAGE_TEMPLATE=Dunyo Taxi: tasdiqlash kodi {code}. Kodni hech kimga bermang.

# ── Matching / dispatch ──────────────────────────────
MATCH_RADII_METERS=3000,5000,8000
DRIVER_ACCEPT_TIMEOUT_SECONDS=15
MIN_DRIVER_BALANCE=-15000
