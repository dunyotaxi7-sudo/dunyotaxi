# Keep the build context small and secrets out of the image.
.git
.gitignore

# Secrets — injected as env vars at runtime, never baked in.
.env
.env.*
!.env.example

# Local Python
.venv/
venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Not part of the API image
admin/
mobile/
uploads/
*.md
*.log
.claude/
.vscode/
.idea/
.DS_Store
