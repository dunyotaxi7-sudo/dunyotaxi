# ── Secrets — NEVER commit ────────────────────────────
# Real config lives on the server / in Vercel's dashboard, never in git.
.env
.env.*
*.env.local
!.env.example
*.pem
*.key

# ── Driver documents (uploaded passports / car photos) ─
uploads/

# ── Runtime data ──────────────────────────────────────
# Redis snapshot — contains live OTP hashes / driver positions.
dump.rdb
*.rdb

# ── Python / backend ──────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Node / JS ─────────────────────────────────────────
node_modules/
.next/
out/
build/
.vercel/
*.tsbuildinfo

# ── Expo / React Native ───────────────────────────────
.expo/
.expo-shared/
dist/
web-build/
# Native projects are regenerated by `npx expo prebuild` (app.config.js is the
# source of truth) and are ~1 GB of build output.
mobile/android/
mobile/ios/

# ── Logs / OS / editors ───────────────────────────────
*.log
npm-debug.log*
yarn-error.log*
.DS_Store
.idea/
.vscode/
