# ── App ──────────────────────────────────────────────
APP_NAME=Dunyo Taxi
ENVIRONMENT=development
DEBUG=true

# ── Database (PostgreSQL + PostGIS) ──────────────────
# async driver for the app, sync driver for alembic is derived automatically
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/buxoro_taxi

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT / Security ───────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200          # 30 days
REFRESH_TOKEN_EXPIRE_MINUTES=129600        # 90 days

# ── OTP ──────────────────────────────────────────────
OTP_TTL_SECONDS=120                        # 2 minutes
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=5
# When true, OTP is returned in the API response & logged instead of sent by SMS
OTP_DEBUG_RETURN=true

# ── Matching ─────────────────────────────────────────
MATCH_RADII_METERS=3000,5000,8000
DRIVER_ACCEPT_TIMEOUT_SECONDS=15

# ── SMS provider ─────────────────────────────────────
# "mock" = log the code (dev). "eskiz" = real SMS via Eskiz.uz.
SMS_PROVIDER=mock

# Eskiz.uz. PREFERRED: email + password (the app logs in and renews the token).
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
# Fallback: pre-issued token. Used only if ESKIZ_PASSWORD is empty; expires ~30d.
ESKIZ_TOKEN=
ESKIZ_FROM=4546
# Must match a template APPROVED in your Eskiz account, or sends are rejected.
OTP_MESSAGE_TEMPLATE=Dunyo Taxi: tasdiqlash kodi {code}. Kodni hech kimga bermang.

# ── OTP abuse limits ─────────────────────────────────
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_PER_PHONE_HOUR=5
OTP_MAX_PER_PHONE_DAY=10
OTP_MAX_PER_IP_HOUR=20

# Legacy (unused):
SMS_API_URL=
SMS_API_TOKEN=
